# OpenAI API key (optional, for GPT-based generation)
OPENAI_API_KEY=your-openai-key-here

# HuggingFace API token (optional, for HF Inference API generation)
HF_API_TOKEN=your-hf-token-here

# Anthropic API key (optional, for Claude-based generation)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Embedding model (default: all-mpnet-base-v2)
EMBEDDING_MODEL=all-mpnet-base-v2

# LLM provider: "openai", "huggingface", or "anthropic"
LLM_PROVIDER=anthropic

# HuggingFace model ID for generation
HF_MODEL_ID=HuggingFaceH4/zephyr-7b-beta

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=data/chroma_db
